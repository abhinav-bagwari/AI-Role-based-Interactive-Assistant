# Copy this file to .env and fill in values for your own provider.
#
# ARIA works without these values in local fallback mode. Set them only when
# you want live model-written agent turns.

BMAD_LLM_MODEL=replace-with-your-model
BMAD_LLM_BASE_URL=https://api.openai.com/v1
BMAD_LLM_WIRE_API=chat
BMAD_LLM_API_KEY=replace-with-your-api-key

# Optional: choose where generated app workspaces are saved.
BMAD_APPLICATIONS_ROOT=./bmad-applications

# Optional tuning.
BMAD_LLM_TEMPERATURE=0.2
BMAD_LLM_TIMEOUT_SECONDS=90
